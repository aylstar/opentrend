---
import TrendShell from "@/components/trends/TrendShell.astro";
import { formatTrendDate, getTrendReports } from "@/lib/trends";

const reports = getTrendReports();
const latest = reports[0];
---

<TrendShell title="GitHub 趋势项目报告">
  <main id="main-content">
    <section class="trend-container trend-hero">
      <div>
        <p class="trend-eyebrow">Daily Reports</p>
        <h1 class="trend-title">GitHub 趋势项目报告</h1>
        <p class="trend-lead">
        每日汇总 GitHub 周榜和月榜项目，面向国内用户提供中文解读、部署判断、商业价值和风险提示。
        </p>
      </div>
    </section>

    {
      latest ? (
        <section class="trend-container trend-section">
          <h2 class="trend-section-title">最新报告</h2>
          <a
            href={`/trends/${latest.slug}/`}
            class="trend-panel mt-4 block p-5"
          >
            <span class="text-lg font-semibold">{latest.title}</span>
            <p class="trend-section-note">{latest.summary.overview}</p>
            <div class="mt-3 flex flex-wrap gap-3 text-sm" style="color: var(--trend-muted)">
              <span>{formatTrendDate(latest.date)}</span>
              <span>{latest.stats.totalProjects} 个项目</span>
              <span>平均推荐 {latest.stats.averageRecommendation}/5</span>
            </div>
          </a>
        </section>
      ) : (
        <section class="trend-container trend-section">
          <h2 class="trend-section-title">暂无报告</h2>
          <p class="trend-section-note">运行 <code>pnpm trends:sample</code> 或 <code>pnpm trends:run</code> 后会自动生成趋势报告。</p>
        </section>
      )
    }

    {
      reports.length > 1 && (
        <section class="trend-container trend-section">
          <h2 class="trend-section-title">历史报告</h2>
          <div class="mt-4 grid gap-3">
            {reports.slice(1).map(report => (
              <a href={`/trends/${report.slug}/`} class="trend-panel rounded-md p-4">
                <span class="font-semibold">{report.title}</span>
                <p class="mt-2 text-sm" style="color: var(--trend-muted)">{report.stats.totalProjects} 个项目 · 平均推荐 {report.stats.averageRecommendation}/5</p>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </main>
</TrendShell>
