---
import TrendShell from "@/components/trends/TrendShell.astro";
import RankBoard from "@/components/trends/RankBoard.astro";
import { formatTrendDate, getTrendProjectMap, getTrendReports } from "@/lib/trends";
import type { TrendProject } from "@/lib/trends";

const reports = getTrendReports();
const latest = reports[0];
const projectMap = getTrendProjectMap();
const pick = (slugs: string[] = []) =>
  slugs
    .map(slug => projectMap.get(slug))
    .filter((project): project is TrendProject => Boolean(project));
const weekly = latest ? pick(latest.sections.weekly) : [];
const monthly = latest ? pick(latest.sections.monthly) : [];
---

<TrendShell title="科技雷达">
  <main id="main-content">
    <section class="trend-container trend-hero">
      <div>
        <p class="trend-eyebrow">Technology Radar</p>
        <h1 class="trend-title">科技雷达</h1>
        <p class="trend-lead">
          {latest
            ? `${formatTrendDate(latest.date)} · GitHub 周榜 / 月榜 · ${latest.stats.totalProjects} 个项目`
            : "等待生成 GitHub 趋势数据"}
        </p>
      </div>
    </section>

    {
      latest ? (
        <section class="trend-container trend-section trend-rank-section">
          <div class="trend-rank-grid">
            <RankBoard title="周趋势排名" subtitle="按 GitHub 周榜顺序展示" projects={weekly} />
            <RankBoard title="月趋势排名" subtitle="按 GitHub 月榜顺序展示" projects={monthly} />
          </div>
        </section>
      ) : (
        <section class="trend-container trend-section">
          <h2 class="trend-section-title">暂无趋势数据</h2>
          <p class="trend-section-note">运行 <code>pnpm trends:sample</code> 或 <code>pnpm trends:run</code> 后会自动生成趋势报告。</p>
        </section>
      )
    }
  </main>
</TrendShell>
