---
import TrendShell from "@/components/trends/TrendShell.astro";
import { formatTrendDate, getTrendProjects, getTrendReports, windowLabel } from "@/lib/trends";

const project = getTrendProjects().find(item => item.slug === Astro.params.slug);
if (!project) return Astro.redirect("/projects/");
const detailParagraphs =
  project.analysis.detailParagraphs && project.analysis.detailParagraphs.length >= 3
    ? project.analysis.detailParagraphs
    : [
        project.analysis.interpretation,
        project.analysis.commercialValue,
        project.analysis.deployment,
      ];
const sections = [
  ["解决的问题", project.analysis.problem],
  ["适合谁使用", project.analysis.audience],
  ["中文深度解读", project.analysis.interpretation],
  ["安装要求", project.analysis.installRequirements],
];
const primaryTags = [
  ...(project.language ? [project.language] : []),
  ...project.trendWindows.map(item => windowLabel(item)),
  ...project.analysis.tags,
].slice(0, 6);
const sourceReport =
  getTrendReports().find(report => report.projectSlugs.includes(project.slug)) ?? getTrendReports()[0];
const sourceReportHref = sourceReport ? `/trends/${sourceReport.slug}/` : "/trends/";
const sourceReportLabel = sourceReport ? formatTrendDate(sourceReport.date) : "趋势报告";
---

<TrendShell title={`${project.fullName} 项目解读`} description={project.analysis.oneLine}>
  <main id="main-content">
    <article>
      <header class="trend-container trend-project-hero">
        <div class="trend-project-copy">
          <nav class="trend-project-nav" aria-label="项目层级导航">
            <a href={sourceReportHref} class="trend-back-link">← 返回趋势报告</a>
            <span>趋势报告</span>
            <span>/</span>
            <span>{sourceReportLabel}</span>
            <span>/</span>
            <strong>{project.repo}</strong>
          </nav>
          <p class="trend-eyebrow">Project Detail</p>
          <h1 class="trend-project-title">{project.repo}</h1>
          <p class="trend-project-author">by {project.owner}</p>
          <p class="trend-project-summary">{project.analysis.oneLine}</p>
          <div class="trend-project-tags" aria-label="项目标签">
            {primaryTags.map(tag => <span>{tag}</span>)}
          </div>
        </div>
      </header>

      <section class="trend-container trend-detail-layout">
        <div class="trend-panel trend-detail-main">
          <section class="trend-detail-card trend-detail-intro">
            <h2>项目介绍</h2>
            {detailParagraphs.map(paragraph => <p>{paragraph}</p>)}
          </section>

          <section class="trend-detail-card">
            <h2>典型使用场景</h2>
            <ul class="trend-scenario-list">
              {project.analysis.scenarios.map(item => <li>{item}</li>)}
            </ul>
          </section>

          {sections.map(([title, content]) => (
            <section class="trend-detail-card">
              <h2>{title}</h2>
              <p>{content}</p>
            </section>
          ))}
        </div>

        <aside class="trend-detail-side">
          <section class="trend-panel trend-side-card">
            <h2>项目指标</h2>
            <div class="trend-metric"><span>推荐指数</span><strong>{project.analysis.recommendation}/5</strong></div>
            <div class="trend-metric"><span>Star</span><strong>{project.stars.toLocaleString()}</strong></div>
            <div class="trend-metric"><span>Fork</span><strong>{project.forks.toLocaleString()}</strong></div>
            <div class="trend-metric"><span>语言</span><strong>{project.language || "未识别"}</strong></div>
            <div class="trend-metric"><span>许可证</span><strong>{project.license || "未识别"}</strong></div>
          </section>

          <section class="trend-panel trend-side-card">
            <h2>官方链接</h2>
            <div class="mt-3 grid gap-3">
              <a class="trend-button primary" href={project.githubUrl}>GitHub</a>
              {project.docsUrl && <a class="trend-button" href={project.docsUrl}>官方文档 / 主页</a>}
              {project.nasUrl && (
                <a class="trend-button" href={project.nasUrl}>国内镜像 / NAS 下载</a>
              )}
            </div>
          </section>
        </aside>
      </section>
    </article>
  </main>
</TrendShell>
