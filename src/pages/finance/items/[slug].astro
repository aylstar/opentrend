---
import TrendShell from "@/components/trends/TrendShell.astro";
import { formatNewsDate, getNewsItems, getNewsReports, newsCategoryLabel } from "@/lib/news";

const item = getNewsItems()
  .filter(item => item.category === "finance")
  .find(item => item.slug === Astro.params.slug);
if (!item) return Astro.redirect("/finance/");
const sourceReport =
  getNewsReports().find(report => (report.sections.finance ?? []).includes(item.id)) ?? getNewsReports()[0];
const reportDate = sourceReport ? formatNewsDate(sourceReport.date) : "";
const chineseParagraphs = String(item.chineseContent || item.chineseSummary || "")
  .split(/\n+/)
  .map(item => item.trim())
  .filter(Boolean);
const englishParagraphs = String(item.content || item.summary || item.originalTitle || "")
  .split(/\n+/)
  .map(item => item.trim())
  .filter(Boolean);
---

<TrendShell title={`${item.chineseTitle} | 财经雷达`} description={item.chineseSummary}>
  <main id="main-content">
    <article class="trend-news-article">
      <header class="trend-container trend-article-hero">
        <nav class="trend-article-nav" aria-label="财经雷达层级导航">
          <a href="/finance/">← 财经雷达</a>
        </nav>
        <p class="trend-article-kicker">财经雷达</p>
        <h1 class="trend-article-title">{item.chineseTitle || item.originalTitle}</h1>
        <p class="trend-article-meta">{item.source} · {newsCategoryLabel(item.category)}{reportDate ? ` · ${reportDate}` : ""}</p>
        {item.chineseSummary && <p class="trend-article-deck">{item.chineseSummary}</p>}
        <p class="trend-original-title">Original: {item.originalTitle}</p>
      </header>

      <section class="trend-container trend-article-layout">
        <div class="trend-article-body">
          <section class="trend-article-section">
            <h2>中文正文</h2>
            {chineseParagraphs.length ? chineseParagraphs.map(paragraph => <p>{paragraph}</p>) : <p>{item.chineseSummary}</p>}
          </section>

          <details class="trend-original-disclosure">
            <summary>英文原文</summary>
            <div>
              {englishParagraphs.length ? englishParagraphs.map(paragraph => <p>{paragraph}</p>) : <p>{item.originalTitle}</p>}
            </div>
          </details>
        </div>

        <aside class="trend-article-side">
          <section class="trend-source-box">
            <span>来源</span>
            <strong>{item.source}</strong>
            <p>{newsCategoryLabel(item.category)}{reportDate ? ` · ${reportDate}` : ""}</p>
            <a class="trend-button primary" href={item.url}>打开原文</a>
            <a class="trend-button" href="/finance/">返回财经雷达</a>
          </section>
        </aside>
      </section>
    </article>
  </main>
</TrendShell>
