---
import TrendShell from "@/components/trends/TrendShell.astro";
import { formatNewsDate, getNewsItems, getNewsReports, newsCategoryLabel } from "@/lib/news";

export function getStaticPaths() {
  return getNewsItems().map(item => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const sourceReport =
  getNewsReports().find(report => [...report.sections.global, ...report.sections.aiTech].includes(item.id)) ??
  getNewsReports()[0];
const reportDate = sourceReport ? formatNewsDate(sourceReport.date) : "";
const paragraphs = String(item.chineseContent || item.chineseSummary || "")
  .split(/\n+/)
  .map(item => item.trim())
  .filter(Boolean);
---

<TrendShell title={`${item.chineseTitle} | 新闻趋势雷达`} description={item.chineseSummary}>
  <main id="main-content">
    <article>
      <header class="trend-container trend-project-hero">
        <div class="trend-project-copy">
          <nav class="trend-project-nav" aria-label="新闻层级导航">
            <a href="/news/" class="trend-back-link">← 返回新闻雷达</a>
            <span>新闻雷达</span>
            {reportDate && <span>/</span>}
            {reportDate && <span>{reportDate}</span>}
            <span>/</span>
            <strong>{item.source}</strong>
          </nav>
          <p class="trend-eyebrow">News Detail</p>
          <h1 class="trend-project-title">{item.chineseTitle || item.originalTitle}</h1>
          <p class="trend-project-author">{item.source} · {newsCategoryLabel(item.category)}</p>
          <p class="trend-project-summary">{item.chineseSummary}</p>
          <div class="trend-project-tags" aria-label="新闻标签">
            {item.tags.map(tag => <span>{tag}</span>)}
          </div>
        </div>
      </header>

      <section class="trend-container trend-detail-layout">
        <div class="trend-panel trend-detail-main">
          <section class="trend-detail-card trend-detail-intro">
            <h2>中文解读</h2>
            {paragraphs.length ? paragraphs.map(paragraph => <p>{paragraph}</p>) : <p>{item.chineseSummary}</p>}
          </section>

          <section class="trend-detail-card">
            <h2>为什么值得关注</h2>
            <p>{item.whyItMatters}</p>
          </section>

          <section class="trend-detail-card">
            <h2>原始标题</h2>
            <p>{item.originalTitle}</p>
          </section>
        </div>

        <aside class="trend-detail-side">
          <section class="trend-panel trend-side-card">
            <h2>新闻指标</h2>
            <div class="trend-metric"><span>来源</span><strong>{item.source}</strong></div>
            <div class="trend-metric"><span>分类</span><strong>{newsCategoryLabel(item.category)}</strong></div>
            <div class="trend-metric"><span>评分</span><strong>{item.score}</strong></div>
            <div class="trend-metric"><span>翻译</span><strong>{item.translationStatus === "translated" ? "已翻译" : "原文降级"}</strong></div>
          </section>

          <section class="trend-panel trend-side-card">
            <h2>原文链接</h2>
            <div class="mt-3 grid gap-3">
              <a class="trend-button primary" href={item.url}>打开原文</a>
              <a class="trend-button" href="/news/">返回新闻雷达</a>
            </div>
          </section>
        </aside>
      </section>
    </article>
  </main>
</TrendShell>
