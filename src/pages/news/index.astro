---
import TrendShell from "@/components/trends/TrendShell.astro";
import NewsRankBoard from "@/components/news/NewsRankBoard.astro";
import { formatNewsDate, getNewsItemMap, getNewsReports } from "@/lib/news";
import type { NewsItem } from "@/lib/news";

const reports = getNewsReports();
const latest = reports[0];
const itemMap = getNewsItemMap();
const pick = (ids: string[] = []) =>
  ids.map(id => itemMap.get(id)).filter((item): item is NewsItem => Boolean(item));

const globalItems = latest ? pick(latest.sections.global) : [];
const techItems = latest ? pick(latest.sections.aiTech) : [];
const youtubeItems = latest ? pick(latest.sections.youtube) : [];
---

<TrendShell title="新闻趋势雷达" description="全球新闻与 AI 科技新闻中文趋势摘要">
  <main id="main-content">
    <section class="trend-container trend-report-header">
      <div class="trend-report-title-block">
        <p class="trend-eyebrow">News Intelligence</p>
        <h1 class="trend-report-title">新闻趋势雷达</h1>
        <p class="trend-report-subtitle">
          {latest ? `${formatNewsDate(latest.date)} · 全球新闻 / AI 科技 / YouTube · ${latest.stats.totalItems} 条` : "等待生成新闻数据"}
        </p>
      </div>
    </section>

    {
      latest ? (
        <>
          <section class="trend-container trend-brief">
            <div class="trend-observation">
              <span>今日观察</span>
              <p>{latest.summary.overview}</p>
            </div>
            <dl class="trend-report-metrics">
              <div><dt>总量</dt><dd>{latest.stats.totalItems}</dd></div>
              <div><dt>全球</dt><dd>{latest.stats.globalItems}</dd></div>
              <div><dt>AI 科技</dt><dd>{latest.stats.techItems}</dd></div>
              <div><dt>YouTube</dt><dd>{latest.stats.youtubeItems ?? 0}</dd></div>
              <div><dt>中文</dt><dd>{latest.stats.translatedItems}</dd></div>
            </dl>
            <div class="trend-tag-strip">
              {latest.sources.slice(0, 8).map(source => <span>{source}</span>)}
            </div>
          </section>

          <section class="trend-container trend-section trend-rank-section">
            <div class="trend-rank-grid">
              <NewsRankBoard title="全球新闻 Top 20" subtitle="GDELT / BBC / Guardian" items={globalItems} />
              <NewsRankBoard title="AI 科技 Top 20" subtitle="HN / Product Hunt / Hugging Face / The Verge" items={techItems} />
              {youtubeItems.length ? (
                <NewsRankBoard title="YouTube 热门视频 Top 10" subtitle="YouTube Data API / Most Popular" items={youtubeItems} />
              ) : null}
            </div>
          </section>

          <section class="trend-container trend-section">
            <div class="trend-panel trend-feature-card">
              <h2>今日结论</h2>
              <p>{latest.summary.conclusion}</p>
            </div>
          </section>

          <section class="trend-container trend-section">
            <h2 class="trend-section-title">历史新闻报告</h2>
            <div class="mt-4 grid gap-3">
              {reports.map(report => (
                <a href={`/news/`} class="trend-panel p-4">
                  <span class="font-semibold">{report.title}</span>
                  <p class="trend-section-note text-sm">{report.stats.totalItems} 条 · {report.sources.join(" / ")}</p>
                </a>
              ))}
            </div>
          </section>
        </>
      ) : (
        <section class="trend-container trend-section">
          <div class="trend-panel trend-feature-card">
            <h2>暂无新闻数据</h2>
            <p>运行 pnpm news:run 后，这里会展示全球新闻 Top 20、AI 科技 Top 20 和 YouTube 热门视频 Top 10。</p>
          </div>
        </section>
      )
    }
  </main>
</TrendShell>
