---
import TrendShell from "@/components/trends/TrendShell.astro";
import NewsRankBoard from "@/components/news/NewsRankBoard.astro";
import { formatNewsDate, getNewsItemsByIds, getNewsReports } from "@/lib/news";
import type { NewsItem } from "@/lib/news";

const reports = getNewsReports();
const latest = reports[0];
const pick = (ids: string[] = []) =>
  getNewsItemsByIds(ids).filter((item): item is NewsItem => Boolean(item));

const youtubeItems = latest ? pick(latest.sections.youtube).slice(0, 10) : [];
---

<TrendShell title="兴趣雷达" description="YouTube 每日热门视频 Top 10">
  <main id="main-content">
    <section class="trend-container trend-report-header">
      <div class="trend-report-title-block">
        <p class="trend-eyebrow">Interest Radar</p>
        <h1 class="trend-report-title">兴趣雷达</h1>
        <p class="trend-report-subtitle">
          {latest ? `${formatNewsDate(latest.date)} · YouTube Top 10` : "等待生成兴趣数据"}
        </p>
      </div>
    </section>

    {
      latest && youtubeItems.length ? (
        <>
          <section class="trend-container trend-section trend-rank-section">
            <div class="trend-rank-grid">
              <NewsRankBoard
                title="YouTube 热门视频 Top 10"
                subtitle="YouTube Data API / Most Popular"
                items={youtubeItems}
                basePath="/youtube/items"
              />
            </div>
          </section>
        </>
      ) : (
        <section class="trend-container trend-section">
          <div class="trend-panel trend-feature-card">
            <h2>暂无 YouTube 数据</h2>
            <p>需要在 GitHub Actions 中配置 YOUTUBE_API_KEY，定时任务运行后这里会展示兴趣雷达中的 YouTube 热门视频 Top 10。</p>
          </div>
        </section>
      )
    }
  </main>
</TrendShell>
