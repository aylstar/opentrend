---
import Layout from "@/layouts/Layout.astro";

type Props = {
  title?: string;
  description?: string;
};

const { title = "开源趋势情报", description = "面向国内用户的开源项目趋势报告" } = Astro.props;
---

<Layout title={title} description={description}>
  <div class="trend-shell">
    <header class="trend-nav">
      <a href="/" class="trend-brand" aria-label="趋势雷达首页">
        <span>趋势雷达</span>
      </a>
      <nav class="trend-nav-links" aria-label="产品导航">
        <a href="/trends/">趋势报告</a>
        <a href="/projects/">项目库</a>
        <a href="/settings/">个人设置</a>
      </nav>
    </header>
    <slot />
  </div>
</Layout>

<style is:global>
  .trend-shell {
    --trend-bg: #f6f7f4;
    --trend-panel: #ffffff;
    --trend-ink: #121411;
    --trend-muted: #747a72;
    --trend-soft: #f0f2ed;
    --trend-line: #dde2d8;
    --trend-accent: #0f6b54;
    --trend-accent-soft: #edf4f0;
    --trend-gold: #8b7a55;
    --trend-silver: #7f8588;
    --trend-bronze: #876f5c;
    min-height: 100svh;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(246, 247, 244, 0.98) 42%, #f6f7f4),
      linear-gradient(rgba(18, 20, 17, 0.028) 1px, transparent 1px),
      linear-gradient(90deg, rgba(18, 20, 17, 0.028) 1px, transparent 1px),
      var(--trend-bg);
    background-size:
      auto,
      2.5rem 2.5rem,
      2.5rem 2.5rem,
      auto;
    color: var(--trend-ink);
    font-family:
      Inter, "PingFang SC", "Microsoft YaHei", system-ui, -apple-system, sans-serif;
  }

  .trend-shell a {
    color: inherit;
    text-decoration: none;
  }

  .trend-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid rgba(20, 24, 19, 0.08);
    background: rgba(247, 248, 245, 0.72);
    padding: 0.8rem max(1rem, calc((100vw - 1180px) / 2));
    backdrop-filter: blur(22px) saturate(145%);
  }

  .trend-brand,
  .trend-nav-links {
    display: flex;
    align-items: center;
  }

  .trend-brand {
    gap: 0.625rem;
    font-weight: 700;
    letter-spacing: 0;
  }

  .trend-brand-mark {
    display: grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    border: 1px solid rgba(20, 24, 19, 0.1);
    border-radius: 0.625rem;
    background: var(--trend-ink);
    color: #fff;
    font-size: 0.75rem;
  }

  .trend-nav-links {
    gap: 0.25rem;
  }

  .trend-nav-links a {
    border-radius: 0.5rem;
    padding: 0.5rem 0.75rem;
    color: #51574f;
    font-size: 0.875rem;
  }

  .trend-nav-links a:hover {
    background: rgba(20, 24, 19, 0.06);
    color: var(--trend-ink);
  }

  .trend-container {
    width: min(1180px, calc(100vw - 2rem));
    margin: 0 auto;
  }

  .trend-report-header {
    padding: 2.5rem 0 0.75rem;
  }

  .trend-report-title-block {
    max-width: 760px;
  }

  .trend-report-title {
    margin-top: 0.5rem;
    max-width: 760px;
    font-size: clamp(1.5rem, 2.5vw, 2.75rem);
    font-weight: 780;
    line-height: 1;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .trend-report-subtitle {
    margin-top: 0.75rem;
    color: var(--trend-muted);
    font-size: 1rem;
    font-weight: 650;
  }

  .trend-brief {
    display: grid;
    gap: 0.875rem;
    align-items: stretch;
    padding-bottom: 0.75rem;
  }

  @media (min-width: 980px) {
    .trend-brief {
      grid-template-columns: minmax(0, 1fr) auto;
    }
  }

  .trend-observation {
    display: grid;
    align-content: center;
    border: 1px solid rgba(18, 20, 17, 0.1);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.76);
    padding: 1rem 1.1rem;
    box-shadow: 0 16px 46px rgba(18, 20, 17, 0.055);
    backdrop-filter: blur(16px);
  }

  .trend-observation span {
    color: var(--trend-accent);
    font-size: 0.75rem;
    font-weight: 780;
  }

  .trend-observation p {
    margin-top: 0.35rem;
    color: #343a34;
    line-height: 1.65;
  }

  .trend-report-metrics {
    display: grid;
    grid-template-columns: repeat(4, minmax(4.5rem, 1fr));
    overflow: hidden;
    border: 1px solid rgba(18, 20, 17, 0.1);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.8);
    box-shadow: 0 18px 54px rgba(18, 20, 17, 0.07);
    backdrop-filter: blur(16px);
  }

  .trend-report-metrics div {
    padding: 0.95rem 1.05rem;
    border-right: 1px solid var(--trend-line);
  }

  .trend-report-metrics div:last-child {
    border-right: 0;
  }

  .trend-report-metrics dt {
    color: var(--trend-muted);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .trend-report-metrics dd {
    margin-top: 0.25rem;
    color: var(--trend-ink);
    font-size: 1.5rem;
    font-weight: 780;
    line-height: 1;
  }

  .trend-tag-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    grid-column: 1 / -1;
  }

  .trend-tag-strip span {
    border: 1px solid rgba(15, 107, 84, 0.16);
    border-radius: 999px;
    background: rgba(232, 243, 238, 0.68);
    padding: 0.35rem 0.65rem;
    color: var(--trend-accent);
    font-size: 0.75rem;
    font-weight: 700;
  }

  .trend-hero {
    display: grid;
    gap: 1rem;
    padding: 3rem 0 1.5rem;
  }

  .trend-home-hero {
    display: grid;
    gap: 1.5rem;
    align-items: start;
    padding: clamp(1.5rem, 3.2vw, 2.75rem) 0 1.25rem;
  }

  @media (min-width: 960px) {
    .trend-home-hero {
      grid-template-columns: minmax(0, 1fr) minmax(22rem, 27rem);
    }
  }

  .trend-home-copy {
    max-width: 760px;
  }

  .trend-home-title {
    max-width: 680px;
    margin-top: 0.55rem;
    color: var(--trend-ink);
    font-size: clamp(2rem, 3.5vw, 3.35rem);
    font-weight: 780;
    line-height: 1.04;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .trend-home-lead {
    max-width: 660px;
    margin-top: 0.85rem;
    color: #5d635c;
    font-size: 0.98rem;
    font-weight: 520;
    line-height: 1.8;
  }

  .trend-home-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.15rem;
  }

  .trend-home-feed {
    display: grid;
    gap: 0.75rem;
    margin-top: 1.35rem;
  }

  @media (min-width: 760px) {
    .trend-home-feed {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .trend-home-feed-card {
    min-height: 7.5rem;
    border: 1px solid rgba(18, 20, 17, 0.09);
    border-radius: 1.15rem;
    background: rgba(255, 255, 255, 0.66);
    padding: 0.95rem;
    box-shadow: 0 18px 52px rgba(18, 20, 17, 0.055);
    backdrop-filter: blur(22px) saturate(130%);
    transition:
      background 160ms ease,
      border-color 160ms ease,
      transform 160ms ease;
  }

  a.trend-home-feed-card:hover {
    border-color: rgba(18, 20, 17, 0.16);
    background: rgba(255, 255, 255, 0.82);
    transform: translateY(-2px);
  }

  .trend-home-feed-card span {
    color: var(--trend-muted);
    font-size: 0.72rem;
    font-weight: 720;
  }

  .trend-home-feed-card h2 {
    margin-top: 0.45rem;
    color: var(--trend-ink);
    font-size: 1rem;
    font-weight: 780;
  }

  .trend-home-feed-card p {
    margin-top: 0.45rem;
    color: var(--trend-muted);
    font-size: 0.84rem;
    line-height: 1.65;
  }

  .trend-home-feed-card.is-muted {
    background: rgba(255, 255, 255, 0.45);
    box-shadow: none;
  }

  .trend-home-card {
    overflow: hidden;
    border: 1px solid rgba(18, 20, 17, 0.09);
    border-radius: 1.2rem;
    background: rgba(255, 255, 255, 0.68);
    box-shadow:
      0 32px 80px rgba(18, 20, 17, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.86);
    backdrop-filter: blur(28px) saturate(135%);
  }

  .trend-settings {
    padding: 2.25rem 0 4rem;
  }

  .trend-settings-grid {
    margin-top: 1.5rem;
  }

  .trend-home-card-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.05rem;
    border-bottom: 1px solid rgba(18, 20, 17, 0.08);
  }

  .trend-home-card-head span,
  .trend-home-highlights span {
    color: var(--trend-muted);
    font-size: 0.76rem;
    font-weight: 720;
  }

  .trend-home-card-head strong {
    color: var(--trend-ink);
    font-size: 0.95rem;
    font-weight: 760;
  }

  .trend-home-metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-bottom: 1px solid rgba(18, 20, 17, 0.08);
  }

  .trend-home-metrics div {
    padding: 0.85rem 0.75rem;
    border-right: 1px solid rgba(18, 20, 17, 0.08);
    text-align: center;
  }

  .trend-home-metrics div:last-child {
    border-right: 0;
  }

  .trend-home-metrics dt {
    color: var(--trend-muted);
    font-size: 0.68rem;
    font-weight: 720;
  }

  .trend-home-metrics dd {
    margin-top: 0.32rem;
    color: var(--trend-ink);
    font-size: 1.55rem;
    font-weight: 790;
    line-height: 1;
  }

  .trend-home-highlights {
    display: grid;
    gap: 0;
  }

  .trend-home-highlights div {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.82rem 1.05rem;
    border-bottom: 1px solid rgba(18, 20, 17, 0.07);
  }

  .trend-home-highlights strong {
    overflow: hidden;
    color: var(--trend-ink);
    font-size: 1rem;
    font-weight: 760;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .trend-home-note {
    padding: 0.9rem 1.05rem 1rem;
    color: var(--trend-muted);
    font-size: 0.82rem;
    line-height: 1.7;
  }

  .trend-section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .trend-section-heading h2 {
    margin-top: 0.25rem;
    color: var(--trend-ink);
    font-size: clamp(1.45rem, 2.2vw, 2.15rem);
    font-weight: 780;
    line-height: 1.12;
  }

  .trend-section-heading > a {
    border: 1px solid rgba(18, 20, 17, 0.08);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.7);
    padding: 0.48rem 0.78rem;
    color: #51574f;
    font-size: 0.78rem;
    font-weight: 720;
  }

  .trend-home-ranks {
    padding-top: 1rem;
  }

  .trend-home-feature-section {
    padding-bottom: 4rem;
  }

  .trend-eyebrow {
    color: var(--trend-accent);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .trend-title {
    max-width: 760px;
    margin-top: 0.35rem;
    font-size: clamp(2rem, 4vw, 4rem);
    font-weight: 760;
    line-height: 1.04;
    letter-spacing: 0;
  }

  .trend-lead {
    max-width: 760px;
    color: var(--trend-muted);
    font-size: 0.975rem;
    line-height: 1.75;
  }

  .trend-lead + .trend-lead {
    margin-top: 0.25rem;
  }

  .trend-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .trend-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    border: 1px solid var(--trend-line);
    border-radius: 0.72rem;
    padding: 0 1rem;
    background: rgba(255, 255, 255, 0.68);
    font-weight: 700;
    box-shadow: 0 8px 24px rgba(18, 20, 17, 0.045);
    transition:
      background 160ms ease,
      border-color 160ms ease,
      transform 160ms ease;
  }

  .trend-button.primary {
    border-color: var(--trend-ink);
    background: var(--trend-ink);
    color: #fff;
  }

  .trend-button:hover {
    border-color: rgba(18, 20, 17, 0.18);
    transform: translateY(-1px);
  }

  .trend-panel {
    border: 1px solid rgba(18, 20, 17, 0.1);
    border-radius: 1.25rem;
    background: rgba(255, 255, 255, 0.72);
    box-shadow:
      0 24px 70px rgba(18, 20, 17, 0.065),
      inset 0 1px 0 rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(24px) saturate(135%);
  }

  .trend-panel::selection,
  .trend-rank-item::selection {
    background: rgba(23, 107, 82, 0.18);
  }

  .trend-section {
    padding: 1.25rem 0;
  }

  .trend-rank-section {
    padding-top: 0.5rem;
  }

  .trend-section-title {
    font-size: 1.5rem;
    font-weight: 760;
    line-height: 1.25;
  }

  .trend-section-note {
    margin-top: 0.5rem;
    color: var(--trend-muted);
    line-height: 1.7;
  }

  .trend-rank-grid {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 900px) {
    .trend-rank-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .trend-rank-board {
    position: relative;
    overflow: hidden;
    padding: 0.875rem 1rem;
  }

  .trend-rank-board::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: "";
    background: linear-gradient(110deg, transparent 0%, rgba(255, 255, 255, 0.78) 42%, transparent 56%);
    opacity: 0.4;
    transform: translateX(-100%);
    animation: trend-sheen 5.5s ease-in-out infinite;
  }

  .trend-rank-board-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.125rem 0.125rem 0.75rem;
  }

  .trend-rank-board h2 {
    font-size: 1.05rem;
    font-weight: 760;
  }

  .trend-rank-board p {
    color: var(--trend-muted);
    font-size: 0.75rem;
  }

  .trend-board-count {
    border: 1px solid var(--trend-line);
    border-radius: 999px;
    padding: 0.25rem 0.5rem;
    color: #4e554e;
    font-size: 0.6875rem;
    font-weight: 700;
    background: rgba(255, 255, 255, 0.72);
  }

  .trend-rank-list {
    display: grid;
    gap: 0;
    perspective: 900px;
  }

  .trend-rank-item {
    --rank-width: 32%;
    position: relative;
    display: grid;
    grid-template-columns: 2.25rem minmax(0, 1fr) auto;
    gap: 0.875rem;
    align-items: center;
    min-height: 3.25rem;
    overflow: hidden;
    border: 0;
    border-bottom: 1px solid rgba(18, 20, 17, 0.07);
    border-radius: 0;
    background: transparent;
    padding: 0.55rem 0.25rem;
    opacity: 0;
    transform: translateY(16px) rotateX(-8deg);
    animation: trend-item-in 560ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--rank-delay, 0ms);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .trend-rank-item::before {
    position: absolute;
    inset: 0 auto 0 0;
    width: var(--rank-width);
    content: "";
    background: linear-gradient(90deg, rgba(18, 20, 17, 0.035), transparent);
    transform-origin: left center;
    animation: trend-bar-in 720ms ease both;
    animation-delay: calc(var(--rank-delay, 0ms) + 160ms);
  }

  .trend-rank-item.is-featured {
    background: transparent;
  }

  .trend-rank-item.is-featured .trend-rank-no {
    box-shadow: none;
  }

  .trend-rank-item.rank-gold .trend-rank-no {
    background: linear-gradient(135deg, #29241a, #9c7a3a);
  }

  .trend-rank-item.rank-silver .trend-rank-no {
    background: linear-gradient(135deg, #24282c, #737d88);
  }

  .trend-rank-item.rank-bronze .trend-rank-no {
    background: linear-gradient(135deg, #2b211b, #8a5d3d);
  }

  .trend-rank-item:hover {
    border-color: rgba(18, 20, 17, 0.1);
    box-shadow: none;
    background: rgba(18, 20, 17, 0.025);
    transform: translateY(-3px) rotateX(0deg);
  }

  .trend-rank-no,
  .trend-rank-main,
  .trend-star-count {
    position: relative;
    z-index: 1;
  }

  .trend-rank-no {
    display: grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    border-radius: 0.625rem;
    background: rgba(18, 20, 17, 0.92);
    color: #f6f7f4;
    font-size: 0.75rem;
    font-weight: 780;
  }

  .trend-rank-main {
    min-width: 0;
  }

  .trend-rank-name {
    display: block;
    overflow: hidden;
    color: #171a16;
    font-size: 0.95rem;
    font-weight: 720;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .trend-rank-author {
    display: block;
    margin-top: 0.1rem;
    overflow: hidden;
    color: var(--trend-muted);
    font-size: 0.75rem;
    line-height: 1.3;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .trend-star-count {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: #7b6a47;
    font-size: 0.875rem;
    font-weight: 680;
    white-space: nowrap;
  }

  .trend-star-count span {
    color: #9a7b35;
    font-size: 0.8rem;
  }

  .trend-card-grid {
    display: grid;
    gap: 1rem;
  }

  .x-trend-section {
    padding-top: 1.75rem;
  }

  .x-trend-header {
    display: grid;
    gap: 1rem;
    align-items: end;
    margin-bottom: 1rem;
  }

  @media (min-width: 900px) {
    .x-trend-header {
      grid-template-columns: minmax(0, 1fr) auto;
    }
  }

  .x-region-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .x-region-tab,
  .x-region-empty {
    min-height: 2rem;
    border: 1px solid rgba(18, 20, 17, 0.09);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.62);
    padding: 0 0.75rem;
    color: var(--trend-muted);
    font-size: 0.75rem;
    font-weight: 720;
  }

  .x-region-tab {
    cursor: pointer;
    transition:
      background 160ms ease,
      color 160ms ease,
      border-color 160ms ease,
      transform 160ms ease;
  }

  .x-region-tab:hover,
  .x-region-tab.is-active {
    border-color: rgba(18, 20, 17, 0.18);
    background: var(--trend-ink);
    color: #fff;
    transform: translateY(-1px);
  }

  .x-region-panel {
    display: none;
  }

  .x-region-panel.is-active {
    display: block;
  }

  .x-region-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: 0.75rem;
    color: var(--trend-muted);
    font-size: 0.75rem;
    font-weight: 700;
  }

  .x-region-meta span {
    border: 1px solid rgba(18, 20, 17, 0.08);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.58);
    padding: 0.25rem 0.55rem;
  }

  .x-trend-grid {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 900px) {
    .x-trend-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .x-trend-list {
    overflow: hidden;
    border: 1px solid rgba(18, 20, 17, 0.1);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 18px 56px rgba(18, 20, 17, 0.06);
    backdrop-filter: blur(18px);
  }

  .x-trend-item {
    position: relative;
    display: grid;
    grid-template-columns: 2.25rem minmax(0, 1fr) auto;
    gap: 0.875rem;
    align-items: center;
    min-height: 3.35rem;
    border-bottom: 1px solid rgba(18, 20, 17, 0.07);
    padding: 0.58rem 0.9rem;
    transition:
      background 160ms ease,
      transform 160ms ease;
  }

  .x-trend-item:last-child {
    border-bottom: 0;
