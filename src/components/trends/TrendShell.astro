---
import Layout from "@/layouts/Layout.astro";

type Props = {
  title?: string;
  description?: string;
};

const { title = "趋势雷达", description = "面向国内用户的信息趋势报告" } = Astro.props;
const pathname = Astro.url.pathname;
const isHome = pathname === "/";
const navItems = [
  { label: "新闻雷达", href: "/news/", match: "/news/" },
  { label: "兴趣雷达", href: "/youtube/", match: "/youtube/" },
  { label: "科技雷达", href: "/trends/", match: "/trends/" },
  { label: "信息库", href: "/library/", match: "/library/" },
  { label: "个人设置", href: "/settings/", match: "/settings/" },
];
---

<Layout title={title} description={description}>
  <div class="trend-shell">
    <header class="trend-nav">
      <a href="/" class="trend-brand" aria-label="趋势雷达首页">
        <span>趋势雷达</span>
      </a>
      <nav class="trend-nav-links" aria-label="产品导航">
        {
          navItems.map(item => (
            <a href={item.href} aria-current={pathname.startsWith(item.match) ? "page" : undefined}>
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>
    {
      !isHome && (
        <div class="trend-return-bar">
          <a href="/" class="trend-home-return">← 返回主界面</a>
        </div>
      )
    }
    <slot />
  </div>
</Layout>

<style is:global>
  .trend-shell {
    --trend-bg: #fbfcf8;
    --trend-panel: #ffffff;
    --trend-ink: #17201b;
    --trend-muted: #6b756d;
    --trend-soft: #f3f7f2;
    --trend-line: #e5ece6;
    --trend-accent: #2f8f83;
    --trend-accent-soft: #eef8f5;
    --trend-blue: #3b82f6;
    --trend-coral: #f27561;
    --trend-violet: #7c6ff6;
    --trend-gold: #b48a3b;
    --trend-silver: #7f8a94;
    --trend-bronze: #a06d4f;
    min-height: 100svh;
    background:
      radial-gradient(circle at 16% 2%, rgba(47, 143, 131, 0.08), transparent 28rem),
      radial-gradient(circle at 84% 10%, rgba(59, 130, 246, 0.07), transparent 30rem),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(251, 252, 248, 0.98) 44%, #fbfcf8),
      var(--trend-bg);
    background-size:
      auto,
      auto,
      auto,
      auto;
    color: var(--trend-ink);
    font-family:
      Inter, "PingFang SC", "Microsoft YaHei", system-ui, -apple-system, sans-serif;
  }

  .trend-shell a {
    color: inherit;
    text-decoration: none;
  }

  .trend-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid rgba(23, 32, 27, 0.07);
    background: rgba(251, 252, 248, 0.82);
    padding: 0.7rem max(1rem, calc((100vw - 1180px) / 2));
    backdrop-filter: blur(22px) saturate(145%);
  }

  .trend-brand,
  .trend-nav-links {
    display: flex;
    align-items: center;
  }

  .trend-brand {
    gap: 0.625rem;
    color: var(--trend-ink);
    font-weight: 760;
    letter-spacing: 0;
  }

  .trend-brand-mark {
    display: grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    border: 1px solid rgba(20, 24, 19, 0.1);
    border-radius: 0.625rem;
    background: var(--trend-ink);
    color: #fff;
    font-size: 0.75rem;
  }

  .trend-nav-links {
    gap: 0.25rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .trend-nav-links a {
    border-radius: 999px;
    padding: 0.42rem 0.7rem;
    color: #59645d;
    font-size: 0.875rem;
  }

  .trend-nav-links a:hover {
    background: rgba(47, 143, 131, 0.08);
    color: var(--trend-ink);
  }

  @media (max-width: 720px) {
    .trend-nav {
      align-items: flex-start;
      flex-direction: column;
    }

    .trend-nav-links {
      justify-content: flex-start;
    }
  }

  .trend-nav-links a[aria-current="page"] {
    background: rgba(47, 143, 131, 0.11);
    color: var(--trend-accent);
    font-weight: 750;
  }

  .trend-return-bar {
    width: min(1180px, calc(100vw - 2rem));
    margin: 0.75rem auto 0;
  }

  .trend-home-return {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(23, 32, 27, 0.08);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    padding: 0.42rem 0.7rem;
    color: var(--trend-muted);
    font-size: 0.8125rem;
    font-weight: 700;
  }

  .trend-home-return:hover {
    background: rgba(47, 143, 131, 0.08);
    color: var(--trend-accent);
  }

  .trend-container {
    width: min(1180px, calc(100vw - 2rem));
    margin: 0 auto;
  }

  .trend-report-header {
    padding: 1.75rem 0 0.65rem;
  }

  .trend-report-title-block {
    max-width: 760px;
  }

  .trend-report-title {
    margin-top: 0.5rem;
    max-width: 760px;
    font-size: clamp(1.45rem, 2.3vw, 2.35rem);
    font-weight: 740;
    line-height: 1;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .trend-report-subtitle {
    margin-top: 0.75rem;
    color: var(--trend-muted);
    font-size: 1rem;
    font-weight: 650;
  }

  .trend-brief {
    display: grid;
    gap: 0.875rem;
    align-items: stretch;
    padding-bottom: 0.75rem;
  }

  @media (min-width: 980px) {
    .trend-brief {
      grid-template-columns: minmax(0, 1fr) auto;
    }
  }

  .trend-observation {
    display: grid;
    align-content: center;
    border: 1px solid rgba(23, 32, 27, 0.07);
    border-radius: 0.9rem;
    background: rgba(255, 255, 255, 0.82);
    padding: 1rem 1.1rem;
    box-shadow: 0 12px 34px rgba(23, 32, 27, 0.04);
    backdrop-filter: blur(16px);
  }

  .trend-observation span {
    color: var(--trend-accent);
    font-size: 0.75rem;
    font-weight: 780;
  }

  .trend-observation p {
    margin-top: 0.35rem;
    color: #343a34;
    line-height: 1.65;
  }

  .trend-report-metrics {
    display: grid;
    grid-template-columns: repeat(4, minmax(4.5rem, 1fr));
    overflow: hidden;
    border: 1px solid rgba(23, 32, 27, 0.08);
    border-radius: 0.9rem;
    background: rgba(255, 255, 255, 0.84);
    box-shadow: 0 12px 34px rgba(23, 32, 27, 0.045);
    backdrop-filter: blur(16px);
  }

  .trend-report-metrics div {
    padding: 0.95rem 1.05rem;
    border-right: 1px solid var(--trend-line);
  }

  .trend-report-metrics div:last-child {
    border-right: 0;
  }

  .trend-report-metrics dt {
    color: var(--trend-muted);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .trend-report-metrics dd {
    margin-top: 0.25rem;
    color: var(--trend-ink);
    font-size: 1.5rem;
    font-weight: 780;
    line-height: 1;
  }

  .trend-tag-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    grid-column: 1 / -1;
  }

  .trend-tag-strip span {
    border: 1px solid rgba(15, 107, 84, 0.16);
    border-radius: 999px;
    background: rgba(232, 243, 238, 0.68);
    padding: 0.35rem 0.65rem;
    color: var(--trend-accent);
    font-size: 0.75rem;
    font-weight: 700;
  }

  .trend-hero {
    display: grid;
    gap: 1rem;
    padding: 2.1rem 0 1rem;
  }

  .trend-home-hero {
    display: grid;
    gap: 1.25rem;
    align-items: start;
    padding: clamp(1.2rem, 2.8vw, 2.15rem) 0 1.1rem;
  }

  @media (min-width: 960px) {
    .trend-home-hero {
      grid-template-columns: minmax(0, 1fr) minmax(22rem, 27rem);
    }
  }

  .trend-home-copy {
    max-width: 760px;
  }

  .trend-home-title {
    max-width: 680px;
    margin-top: 0.55rem;
    color: var(--trend-ink);
    font-size: clamp(1.9rem, 3vw, 2.85rem);
    font-weight: 740;
    line-height: 1.08;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .trend-home-lead {
    max-width: 660px;
    margin-top: 0.85rem;
    color: #657169;
    font-size: 0.98rem;
    font-weight: 520;
    line-height: 1.8;
  }

  .trend-home-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.15rem;
  }

  .trend-home-feed {
    display: grid;
    gap: 0.75rem;
    margin-top: 1.35rem;
  }

  @media (min-width: 760px) {
    .trend-home-feed {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .trend-home-feed-card {
    min-height: 7.5rem;
    border: 1px solid rgba(23, 32, 27, 0.07);
    border-radius: 0.95rem;
    background: rgba(255, 255, 255, 0.78);
    padding: 0.95rem;
    box-shadow: 0 10px 30px rgba(23, 32, 27, 0.035);
    backdrop-filter: blur(22px) saturate(130%);
    transition:
      background 160ms ease,
      border-color 160ms ease,
      transform 160ms ease;
  }

  .trend-home-feed-card:nth-child(1) {
    --module-color: var(--trend-blue);
  }

  .trend-home-feed-card:nth-child(2) {
    --module-color: var(--trend-coral);
  }

  .trend-home-feed-card:nth-child(3) {
    --module-color: var(--trend-accent);
  }

  .trend-home-feed-card::before {
    display: block;
    width: 1.55rem;
    height: 0.2rem;
    border-radius: 999px;
    background: var(--module-color, var(--trend-accent));
    content: "";
    opacity: 0.75;
  }

  a.trend-home-feed-card:hover {
    border-color: rgba(47, 143, 131, 0.22);
    background: rgba(255, 255, 255, 0.9);
    transform: translateY(-2px);
  }

  .trend-home-feed-card span {
    display: block;
    margin-top: 0.7rem;
    color: var(--module-color, var(--trend-accent));
    font-size: 0.72rem;
    font-weight: 720;
  }

  .trend-home-feed-card h2 {
    margin-top: 0.45rem;
    color: var(--trend-ink);
    font-size: 1rem;
    font-weight: 780;
  }

  .trend-home-feed-card p {
    margin-top: 0.45rem;
    color: var(--trend-muted);
    font-size: 0.84rem;
    line-height: 1.65;
  }

  .trend-home-feed-card.is-muted {
    background: rgba(255, 255, 255, 0.45);
    box-shadow: none;
  }

  .trend-home-card {
    overflow: hidden;
    border: 1px solid rgba(23, 32, 27, 0.075);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 18px 54px rgba(23, 32, 27, 0.055);
    backdrop-filter: blur(28px) saturate(135%);
  }

  .trend-settings {
    padding: 2.25rem 0 4rem;
  }

  .trend-settings-grid {
    margin-top: 1.5rem;
  }

  .trend-home-card-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.05rem;
    border-bottom: 1px solid rgba(23, 32, 27, 0.065);
  }

  .trend-home-card-head span,
  .trend-home-highlights span {
    color: var(--trend-muted);
    font-size: 0.76rem;
    font-weight: 720;
  }

  .trend-home-card-head strong {
    color: var(--trend-ink);
    font-size: 0.95rem;
    font-weight: 760;
  }

  .trend-home-metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-bottom: 1px solid rgba(23, 32, 27, 0.065);
  }

  .trend-home-metrics div {
    padding: 0.85rem 0.75rem;
    border-right: 1px solid rgba(23, 32, 27, 0.065);
    text-align: center;
  }

  .trend-home-metrics div:last-child {
    border-right: 0;
  }

  .trend-home-metrics dt {
    color: var(--trend-muted);
    font-size: 0.68rem;
    font-weight: 720;
  }

  .trend-home-metrics dd {
    margin-top: 0.32rem;
    color: var(--trend-ink);
    font-size: 1.45rem;
    font-weight: 760;
    line-height: 1;
  }

  .trend-home-metrics div:nth-child(1) dd {
    color: var(--trend-accent);
  }

  .trend-home-metrics div:nth-child(2) dd {
    color: var(--trend-blue);
  }

  .trend-home-metrics div:nth-child(3) dd {
    color: var(--trend-coral);
  }

  .trend-home-metrics div:nth-child(4) dd {
    color: var(--trend-violet);
  }

  .trend-home-highlights {
    display: grid;
    gap: 0;
  }

  .trend-home-highlights div {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.82rem 1.05rem;
    border-bottom: 1px solid rgba(23, 32, 27, 0.06);
  }

  .trend-home-highlights strong {
    overflow: hidden;
    color: var(--trend-ink);
    font-size: 0.92rem;
    font-weight: 720;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .trend-home-note {
    padding: 0.9rem 1.05rem 1rem;
    color: var(--trend-muted);
    font-size: 0.82rem;
    line-height: 1.7;
  }

  .trend-section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .trend-section-heading h2 {
    margin-top: 0.25rem;
    color: var(--trend-ink);
    font-size: clamp(1.25rem, 1.8vw, 1.75rem);
    font-weight: 740;
    line-height: 1.12;
  }

  .trend-section-heading > a {
    border: 1px solid rgba(23, 32, 27, 0.07);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.78);
    padding: 0.48rem 0.78rem;
    color: #56635c;
    font-size: 0.78rem;
    font-weight: 720;
  }

  .trend-home-ranks {
    padding-top: 1rem;
  }

  .trend-home-feature-section {
    padding-bottom: 4rem;
  }

  .trend-eyebrow {
    color: var(--trend-accent);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .trend-title {
    max-width: 760px;
    margin-top: 0.35rem;
    font-size: clamp(1.9rem, 3.3vw, 3rem);
    font-weight: 730;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .trend-lead {
    max-width: 760px;
    color: var(--trend-muted);
    font-size: 0.975rem;
    line-height: 1.75;
  }

  .trend-lead + .trend-lead {
    margin-top: 0.25rem;
  }

  .trend-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .trend-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    border: 1px solid rgba(23, 32, 27, 0.08);
    border-radius: 999px;
    padding: 0 1rem;
    background: rgba(255, 255, 255, 0.68);
    color: #51615a;
    font-weight: 700;
    box-shadow: 0 8px 22px rgba(23, 32, 27, 0.035);
    transition:
      background 160ms ease,
      border-color 160ms ease,
      transform 160ms ease;
  }

  .trend-button.primary {
    border-color: rgba(47, 143, 131, 0.22);
    background: var(--trend-accent);
    color: #fff;
  }

  .trend-button:hover {
    border-color: rgba(47, 143, 131, 0.22);
    transform: translateY(-1px);
  }

  .trend-panel {
    border: 1px solid rgba(23, 32, 27, 0.075);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 14px 42px rgba(23, 32, 27, 0.045);
    backdrop-filter: blur(24px) saturate(135%);
  }

  .trend-panel::selection,
  .trend-rank-item::selection {
    background: rgba(23, 107, 82, 0.18);
  }

  .trend-section {
    padding: 1.25rem 0;
  }

  .trend-rank-section {
    padding-top: 0.5rem;
  }

  .trend-section-title {
    font-size: 1.5rem;
    font-weight: 760;
    line-height: 1.25;
  }

  .trend-section-note {
    margin-top: 0.5rem;
    color: var(--trend-muted);
    line-height: 1.7;
  }

  .trend-rank-grid {
    display: grid;
    gap: 0.9rem;
  }

  @media (min-width: 900px) {
    .trend-rank-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .trend-rank-board {
    position: relative;
    overflow: hidden;
    padding: 0.8rem 0.95rem;
  }

  .trend-rank-board::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: "";
    background: linear-gradient(110deg, transparent 0%, rgba(255, 255, 255, 0.52) 42%, transparent 56%);
    opacity: 0.28;
    transform: translateX(-100%);
    animation: trend-sheen 5.5s ease-in-out infinite;
  }

  .trend-rank-board-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.125rem 0.125rem 0.65rem;
  }

  .trend-rank-board h2 {
    font-size: 1rem;
    font-weight: 740;
  }

  .trend-rank-board p {
    color: var(--trend-muted);
    font-size: 0.75rem;
  }

  .trend-board-count {
    border: 1px solid rgba(23, 32, 27, 0.07);
    border-radius: 999px;
    padding: 0.25rem 0.5rem;
    color: #5c6860;
    font-size: 0.6875rem;
    font-weight: 700;
    background: rgba(255, 255, 255, 0.8);
  }

  .trend-rank-list {
    display: grid;
    gap: 0;
    perspective: 900px;
  }

  .trend-rank-item {
    --rank-width: 32%;
    position: relative;
    display: grid;
    grid-template-columns: 2.1rem minmax(0, 1fr) auto;
    gap: 0.8rem;
    align-items: center;
    min-height: 3.1rem;
    overflow: hidden;
    border: 0;
    border-bottom: 1px solid rgba(23, 32, 27, 0.06);
    border-radius: 0;
    background: transparent;
    padding: 0.55rem 0.25rem;
    opacity: 0;
    transform: translateY(10px);
    animation: trend-item-in 560ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--rank-delay, 0ms);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .trend-rank-item::before {
    position: absolute;
    inset: 0 auto 0 0;
    width: var(--rank-width);
    content: "";
    background: linear-gradient(90deg, rgba(47, 143, 131, 0.055), transparent);
    transform-origin: left center;
    animation: trend-bar-in 720ms ease both;
    animation-delay: calc(var(--rank-delay, 0ms) + 160ms);
  }

  .trend-rank-item.is-featured {
    background: transparent;
  }

  .trend-rank-item.is-featured .trend-rank-no {
    box-shadow: none;
  }

  .trend-rank-item.rank-gold .trend-rank-no {
    background: #fff4d8;
    color: #9b6d15;
  }

  .trend-rank-item.rank-silver .trend-rank-no {
    background: #eef3f5;
    color: #64727d;
  }

  .trend-rank-item.rank-bronze .trend-rank-no {
    background: #fff0e8;
    color: #9a6142;
  }

  .trend-rank-item:hover {
    border-color: rgba(47, 143, 131, 0.14);
    box-shadow: none;
    background: rgba(47, 143, 131, 0.045);
    transform: translateX(3px);
  }

  .trend-rank-no,
  .trend-rank-main,
  .trend-star-count {
    position: relative;
    z-index: 1;
  }

  .trend-rank-no {
    display: grid;
    width: 1.9rem;
    height: 1.9rem;
    place-items: center;
    border-radius: 0.58rem;
    background: #eef7f4;
    color: var(--trend-accent);
    font-size: 0.75rem;
    font-weight: 780;
  }

  .trend-rank-main {
    min-width: 0;
  }

  .trend-rank-name {
    display: block;
    overflow: hidden;
    color: #1f2a24;
    font-size: 0.93rem;
    font-weight: 700;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .trend-rank-author {
    display: block;
    margin-top: 0.1rem;
    overflow: hidden;
    color: var(--trend-muted);
    font-size: 0.75rem;
    line-height: 1.3;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .trend-star-count {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: #8a6b22;
    font-size: 0.875rem;
    font-weight: 680;
    white-space: nowrap;
  }

  .trend-star-count span {
    color: #9a7b35;
